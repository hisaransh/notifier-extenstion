{
  "manifest_version": 3,
  "name": "PR & Jenkins Bell Notifier",
  "description": "Background notifications for merge-ready GitHub PRs and completed Jenkins builds.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": [
    "notifications",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "github-monitor.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "https://github.com/*"
      ],
      "js": [
        "jenkins-monitor.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Open PR & Jenkins Bell Notifier settings"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
